# Copia este archivo a ".env" en local (nunca subas .env a Git).
# En Render: Environment → Add Environment Variable (una fila por variable).

# --- App ---
NODE_ENV=production
# PORT lo define Render automáticamente; en local puedes usar 3000

# --- PostgreSQL (en Render: copia host/usuario/contraseña/base desde el panel de la BD) ---
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=
DB_NAME=mobile_commerce

# --- JWT ---
JWT_SECRET=

# --- Cloudinary (dashboard de Cloudinary) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- CORS: URL del front (Vercel). Varias URLs separadas por coma ---
# FRONTEND_URL=https://tu-app.vercel.app

# Opcional
# SESSION_DURATION_MS=7200000
